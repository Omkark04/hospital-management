# =============================================================
# HMS Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================

# Django Core
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for dev — switch to PostgreSQL for prod)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=hms_db
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# SendGrid Email
SENDGRID_API_KEY=your-sendgrid-api-key-here
DEFAULT_FROM_EMAIL=noreply@yourhospital.com
DEFAULT_FROM_NAME=Hospital Management System

# Cloudinary — Image Storage (add credentials later)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Dropbox — Document Storage (add credentials later)
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret
DROPBOX_REFRESH_TOKEN=your-dropbox-refresh-token

# WhatsApp Enquiry Number (for product listings)
WHATSAPP_ENQUIRY_NUMBER=+919XXXXXXXXX
