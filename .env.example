# =========================================================================
# VERCEL DEPLOYMENT CONFIGURATION & ENVIRONMENT VARIABLES
# =========================================================================

# -----------------
# 1. DATABASE
# -----------------
# If DATABASE_URL is present, Django will connect to the PostgreSQL database
# (e.g., from Railway). If left blank/commented, it falls back to the local SQLite DB.
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://your_railway_user:password@containers-us-west-XX.railway.app:5432/railway

# -----------------
# 2. DJANGO BACKEND
# -----------------
# Security key for Django. Make sure this is unique and secret in production.
SECRET_KEY=your_super_secret_django_key_here

# Set to False in production!
DEBUG=False

# Allowed origins for CORS (so your Vercel frontend can call your Vercel backend)
# Add your final Vercel production deployment URL here. 
# Do not include a trailing slash at the end!
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-project-url.vercel.app

# -----------------
# 3. FRONTEND (Vite / React)
# -----------------
# Vite needs to know where the backend API is. 
# During local development: http://127.0.0.1:8000
# On Vercel: Provide the absolute URL to your Vercel deployment if it's separate,
# OR simply use /api if they are deployed together using the vercel.json rewrite rules.
VITE_API_BASE_URL=/api

# -----------------
# 4. THIRD-PARTY APIs (For Backend)
# -----------------
# JWT authentication timeouts
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# SendGrid Email
SENDGRID_API_KEY=your_sendgrid_key_here
DEFAULT_FROM_EMAIL=noreply@yourhospital.com
DEFAULT_FROM_NAME=Hospital Management System

# Cloudinary (Product & Gallery Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Dropbox (Patient Lab Reports)
DROPBOX_APP_KEY=your_dropbox_key
DROPBOX_APP_SECRET=your_dropbox_secret
DROPBOX_REFRESH_TOKEN=your_dropbox_token

# WhatsApp (Enquiry redirection)
WHATSAPP_ENQUIRY_NUMBER=+919763331118
