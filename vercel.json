{
  "version": 2,
  "builds": [
    {
      "src": "backend/backend/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/backend/wsgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/backend/backend/wsgi.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/backend/backend/wsgi.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
